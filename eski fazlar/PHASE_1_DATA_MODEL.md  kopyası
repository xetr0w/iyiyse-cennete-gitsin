**Path:** `app/src/main/java/com/yourdomain/notes/domain/model/DrawingDataModels.kt`

```kotlin
package com.yourdomain.notes.domain.model

import java.util.UUID

// ─────────────────────────────────────────────────────────────────────────────
// TOOL TYPE
[cite_start]// Yeni bir tool eklenirken sadece buraya yeni bir enum sabiti eklenir. [cite: 3]
[cite_start]// Mevcut sabitler HİÇBİR ZAMAN yeniden adlandırılmaz veya silinmez; [cite: 3]
[cite_start]// bu değerler ileride bulut veritabanında ve CRDT log'larında saklanacak. [cite: 4]
// ─────────────────────────────────────────────────────────────────────────────

enum class ToolType {
    BALLPOINT_PEN,
    FOUNTAIN_PEN,
    HIGHLIGHTER,
    MARKER,
    ERASER
}

// ─────────────────────────────────────────────────────────────────────────────
// STYLUS POINT
//
[cite_start]// Tek bir dokunma noktasını temsil eder. [cite: 5]
//
// [x], [y] KESİNLİKLE fiziksel cihaz pikselleri DEĞİLDİR.
// Page modelindeki widthPx ve heightPx sınırlarına göre oranlanmış (Canonical) koordinatlardır.
// (Örn: 0..2000f arası). Bu sayede farklı çözünürlüklerde çizimler kaymaz.
//
[cite_start]// [pressure] 0.0f – 1.0f aralığında normalize edilmiş değer. [cite: 6]
[cite_start]// Ham hardware değeri değil; input katmanında normalize edilerek buraya gelir. [cite: 7]
//
// [tilt], [orientation] Kalemin fiziksel eğim (radyan) ve yön açıları. (Örn: S-Pen verisi)
//
[cite_start]// [timestamp] KESİNLİKLE nanosaniye cinsinden olmalıdır. [cite: 5]
[cite_start]// Kaynak: System.nanoTime() veya MotionEvent.getEventTime() * 1_000_000L [cite: 5]
[cite_start]// Milisaniye kullanmak CRDT çakışmalarına ve hatalı hız hesabına yol açar — YAPILMAZ. [cite: 6]
// ─────────────────────────────────────────────────────────────────────────────

data class StylusPoint(
    val x: Float,
    val y: Float,
    val pressure: Float,
    val tilt: Float,
    val orientation: Float,
    val timestamp: Long  // nanoseconds — MUST NOT be changed to milliseconds
)

// ─────────────────────────────────────────────────────────────────────────────
// STROKE
//
[cite_start]// Tek bir kesintisiz çizim hamlesi. [cite: 8]
//
// [id] UUID v4 string. [cite_start]Üretim mantığına DOKUNULMAZ. [cite: 8]
[cite_start]//      Gerçek zamanlı işbirliği ve CRDT merge operasyonları bu ID'ye bağlıdır. [cite: 9]
//
// [createdAt] Nanosaniye. [cite_start]Stroke'un ilk StylusPoint'i alındığı an atanır. [cite: 9]
//
// [version] CRDT çakışma çözümü (Conflict Resolution) için kullanılır.
//           Her DeleteStrokeCommand veya güncellemede 'System.nanoTime()' olarak set edilir.
//
// [isDeleted] Soft-delete flag. [cite_start]Stroke fiziksel olarak silinmez; [cite: 9, 10]
[cite_start]//             komut katmanı bu flag'i true yapan yeni bir kopya üretir (copy()). [cite: 10]
[cite_start]//             Bu sayede CRDT undo/redo log'u bozulmaz. [cite: 11]
//
// [points] Immutable liste. [cite_start]Stroke oluşturulduktan sonra nokta eklenemez. [cite: 12]
[cite_start]//          Aktif çizim sırasında geçici buffer input katmanında tutulur; [cite: 12]
[cite_start]//          çizim tamamlandığında bu model oluşturulur. [cite: 13]
//
// [color] ARGB int. [cite_start]Örnek: 0xFF000000.toInt() → opak siyah. [cite: 14]
//
[cite_start]// [baseWidth] Piksel cinsinden temel kalem genişliği. [cite: 14, 15]
[cite_start]//             Pressure çarpanı C++ katmanında uygulanır, burada saklanmaz. [cite: 15]
//
// [textMetadata] İleride eklenecek OCR/Yapay Zeka tanıma verileri için opsiyonel alan.
// ─────────────────────────────────────────────────────────────────────────────

data class Stroke(
    val id: String = UUID.randomUUID().toString(),
    val toolType: ToolType,
    val color: Int,
    val baseWidth: Float,
    val points: List<StylusPoint>,
    val createdAt: Long,  // nanoseconds — MUST NOT be changed to milliseconds
    val version: Long = System.nanoTime(),
    val isDeleted: Boolean = false,
    val textMetadata: String? = null
)

// ─────────────────────────────────────────────────────────────────────────────
// LAYER
//
// Karmaşık çizimlerde Z-Index (Derinlik) yönetimini sağlar.
//
// [strokes] Immutable liste. Layer değiştirilmek istendiğinde copy() üretilir.
//
// DİKKAT: 'order' gibi bir Int alan kullanılmaz. Layer'ın derinlik sırası (Z-Index),
// Page.layers listesi içindeki indeks pozisyonu ile belirlenir. Bu kural çakışmaları önler.
// ─────────────────────────────────────────────────────────────────────────────

data class Layer(
    val id: String = UUID.randomUUID().toString(),
    val title: String,
    val strokes: List<Stroke> = emptyList(),
    val isVisible: Boolean = true,
    val isLocked: Boolean = false
)

// ─────────────────────────────────────────────────────────────────────────────
// PAGE
//
[cite_start]// Bir not sayfasını temsil eder. [cite: 16, 17]
//
// [pageNumber] 1-indexed. [cite_start]Sayfa sıralaması bu değere göre yapılır. [cite: 17]
//
// [widthPx], [heightPx] Canonical Canvas (Sanal Sayfa) boyutları.
// Fiziksel cihazın çözünürlüğü ne olursa olsun, C++ ve veri katmanı bu sınırları baz alır.
//
// [layers] Immutable liste. [cite_start]Sayfa değiştirilmek istendiğinde [cite: 18]
[cite_start]//          komut katmanı copy() ile yeni bir Page üretir. [cite: 18]
[cite_start]//          Listeye doğrudan eleman eklenmez/çıkarılmaz. [cite: 19]
// ─────────────────────────────────────────────────────────────────────────────

data class Page(
    val id: String = UUID.randomUUID().toString(),
    val pageNumber: Int,
    val widthPx: Float = 2000f,  // Canonical width
    val heightPx: Float = 3000f, // Canonical height
    val layers: List<Layer> = listOf(Layer(title = "Default"))
)

// ─────────────────────────────────────────────────────────────────────────────
// NOTEBOOK
//
// Uygulamanın en üst seviye doküman yapısı. Sayfaları ve meta verileri barındırır.
// ─────────────────────────────────────────────────────────────────────────────

data class Notebook(
    val id: String = UUID.randomUUID().toString(),
    val title: String,
    val pages: List<Page> = emptyList(),
    val createdAt: Long = System.currentTimeMillis(),
    val lastModifiedAt: Long = System.currentTimeMillis(),
    val coverColor: Int
)
```

// ─────────────────────────────────────────────────────────────────────────────
